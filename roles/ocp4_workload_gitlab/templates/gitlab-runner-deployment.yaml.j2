---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gitlab-runner
  namespace: {{ ocp4_workload_gitlab_namespace }}
spec:
  replicas: {{ ocp4_workload_gitlab_runner_replicas }}
  selector:
    matchLabels:
      app: gitlab-runner
  template:
    metadata:
      labels:
        app: gitlab-runner
    spec:
      serviceAccountName: gitlab-runner
      initContainers:
      - name: configure-runner
        image: {{ ocp4_workload_gitlab_runner_image }}:{{ ocp4_workload_gitlab_runner_image_tag }}
        command: ["/bin/sh"]
        args:
        - -c
        - |
          set -e
          # Register to get auth token
          RUNNER_TOKEN=$(gitlab-runner register \
            --non-interactive \
            --url "http://gitlab:8080" \
            --registration-token "${REGISTRATION_TOKEN}" \
            --executor "{{ ocp4_workload_gitlab_runner_executor }}" \
            --output-limit 0 \
            2>&1 | grep -oP 'token=\K[a-zA-Z0-9_-]+' || echo "")

          if [ -z "$RUNNER_TOKEN" ]; then
            echo "Failed to extract runner token, trying alternative method..."
            # Try registering normally and extract from config
            gitlab-runner register \
              --non-interactive \
              --url "http://gitlab:8080" \
              --registration-token "${REGISTRATION_TOKEN}" \
              --executor "{{ ocp4_workload_gitlab_runner_executor }}" \
              --config /tmp/temp-config.toml
            RUNNER_TOKEN=$(grep 'token =' /tmp/temp-config.toml | cut -d'"' -f2)
          fi

          echo "Got runner token: ${RUNNER_TOKEN:0:10}..."

          # Create final config from template
          sed "s/__GITLAB_RUNNER_TOKEN__/${RUNNER_TOKEN}/" /templates/config-template.toml > /etc/gitlab-runner/config.toml
          chmod 600 /etc/gitlab-runner/config.toml

          echo "Configuration created successfully"
          cat /etc/gitlab-runner/config.toml
        env:
        - name: REGISTRATION_TOKEN
          valueFrom:
            secretKeyRef:
              name: gitlab-runner-token
              key: token
        volumeMounts:
        - name: config
          mountPath: /etc/gitlab-runner
        - name: config-template
          mountPath: /templates
      containers:
      - name: gitlab-runner
        image: {{ ocp4_workload_gitlab_runner_image }}:{{ ocp4_workload_gitlab_runner_image_tag }}
        imagePullPolicy: Always
        command:
        - gitlab-runner
        - run
        - --user=gitlab-runner
        - --working-directory=/home/gitlab-runner
        volumeMounts:
        - name: config
          mountPath: /etc/gitlab-runner
        resources:
          requests:
            memory: {{ ocp4_workload_gitlab_runner_memory_request }}
            cpu: {{ ocp4_workload_gitlab_runner_cpu_request }}
          limits:
            memory: {{ ocp4_workload_gitlab_runner_memory_limit }}
            cpu: {{ ocp4_workload_gitlab_runner_cpu_limit }}
      volumes:
      - name: config
        emptyDir: {}
      - name: config-template
        configMap:
          name: gitlab-runner-config-template
