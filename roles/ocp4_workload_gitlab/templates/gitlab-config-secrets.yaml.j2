---
apiVersion: v1
kind: Secret
metadata:
  name: gitlab-secrets
  namespace: {{ ocp4_workload_gitlab_namespace }}
type: Opaque
stringData:
  GITLAB_ROOT_PASSWORD: "{{ ocp4_workload_gitlab_root_password }}"
  POSTGRES_USER: "{{ ocp4_workload_gitlab_postgresql_user }}"
  POSTGRES_PASSWORD: "{{ ocp4_workload_gitlab_postgresql_password }}"
  POSTGRES_DB: "{{ ocp4_workload_gitlab_postgresql_database }}"
  REDIS_PASSWORD: "{{ ocp4_workload_gitlab_redis_password }}"
{% if ocp4_workload_gitlab_auth_mode == 'keycloak' %}
  KEYCLOAK_CLIENT_SECRET: "{{ _ocp4_workload_gitlab_keycloak_client_secret }}"
{% endif %}
---
apiVersion: v1
kind: Secret
metadata:
  name: gitlab-omnibus-config
  namespace: {{ ocp4_workload_gitlab_namespace }}
type: Opaque
stringData:
  gitlab.rb: |
    external_url 'https://{{ _ocp4_workload_gitlab_route }}'
    gitlab_rails['initial_root_password'] = ENV['GITLAB_ROOT_PASSWORD']
    postgresql['enable'] = false
    gitlab_rails['db_adapter'] = 'postgresql'
    gitlab_rails['db_encoding'] = 'unicode'
    gitlab_rails['db_host'] = 'postgresql'
    gitlab_rails['db_port'] = 5432
    gitlab_rails['db_database'] = ENV['POSTGRES_DB']
    gitlab_rails['db_username'] = ENV['POSTGRES_USER']
    gitlab_rails['db_password'] = ENV['POSTGRES_PASSWORD']
    redis['enable'] = false
    gitlab_rails['redis_host'] = 'redis'
    gitlab_rails['redis_port'] = 6379
    gitlab_rails['redis_password'] = ENV['REDIS_PASSWORD']
    nginx['listen_port'] = 8080
    nginx['listen_https'] = false
    nginx['custom_gitlab_server_config'] = "server_name _;\n"
    gitlab_rails['gitlab_shell_ssh_port'] = 2222
    puma['port'] = 0
    puma['worker_processes'] = 2
    puma['min_threads'] = 4
    puma['max_threads'] = 4
    puma['worker_timeout'] = 60
    puma['per_worker_max_memory_mb'] = 1024
{% if ocp4_workload_gitlab_auth_mode == 'keycloak' %}
    gitlab_rails['omniauth_enabled'] = true
    gitlab_rails['omniauth_allow_single_sign_on'] = ['openid_connect']
    gitlab_rails['omniauth_block_auto_created_users'] = false
    gitlab_rails['omniauth_providers'] = [
      {
        'name' => 'openid_connect',
        'label' => 'Keycloak',
        'args' => {
          'name' => 'openid_connect',
          'scope' => ['openid','profile','email'],
          'response_type' => 'code',
          'issuer' => '{{ _ocp4_workload_gitlab_keycloak_url }}/realms/{{ ocp4_workload_gitlab_keycloak_realm }}',
          'discovery' => true,
          'client_auth_method' => 'query',
          'uid_field' => 'preferred_username',
          'client_options' => {
            'identifier' => '{{ ocp4_workload_gitlab_keycloak_client_id }}',
            'secret' => ENV['KEYCLOAK_CLIENT_SECRET'],
            'redirect_uri' => 'https://{{ _ocp4_workload_gitlab_route }}/users/auth/openid_connect/callback'
          }
        }
      }
    ]
{% endif %}
