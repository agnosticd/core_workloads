---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: gitlab-ce
  namespace: {{ ocp4_workload_gitlab_namespace }}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: gitlab-ce-anyuid
  namespace: {{ ocp4_workload_gitlab_namespace }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: system:openshift:scc:anyuid
subjects:
- kind: ServiceAccount
  name: gitlab-ce
  namespace: {{ ocp4_workload_gitlab_namespace }}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: gitlab-prometheus-k8s-read
rules:
- apiGroups: [""]
  resources: ["nodes", "pods"]
  verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: gitlab-ce-prometheus-k8s-read
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: gitlab-prometheus-k8s-read
subjects:
- kind: ServiceAccount
  name: gitlab-ce
  namespace: {{ ocp4_workload_gitlab_namespace }}
---
apiVersion: v1
kind: Secret
metadata:
  name: gitlab-secrets
  namespace: {{ ocp4_workload_gitlab_namespace }}
type: Opaque
stringData:
  GITLAB_ROOT_PASSWORD: "{{ ocp4_workload_gitlab_root_password }}"
  POSTGRES_USER: "{{ ocp4_workload_gitlab_postgresql_user }}"
  POSTGRES_PASSWORD: "{{ ocp4_workload_gitlab_postgresql_password }}"
  POSTGRES_DB: "{{ ocp4_workload_gitlab_postgresql_database }}"
  REDIS_PASSWORD: "{{ ocp4_workload_gitlab_redis_password }}"
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: gitlab-data
  namespace: {{ ocp4_workload_gitlab_namespace }}
spec:
  accessModes:
  - ReadWriteOnce
  resources:
    requests:
      storage: {{ ocp4_workload_gitlab_volume_size }}
{% if ocp4_workload_gitlab_volume_storage_class | length > 0 %}
  storageClassName: {{ ocp4_workload_gitlab_volume_storage_class }}
{% endif %}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: postgresql-data
  namespace: {{ ocp4_workload_gitlab_namespace }}
spec:
  accessModes:
  - ReadWriteOnce
  resources:
    requests:
      storage: {{ ocp4_workload_gitlab_postgresql_volume_size }}
{% if ocp4_workload_gitlab_postgresql_volume_storage_class | length > 0 %}
  storageClassName: {{ ocp4_workload_gitlab_postgresql_volume_storage_class }}
{% endif %}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgresql
  namespace: {{ ocp4_workload_gitlab_namespace }}
  labels:
    app: postgresql
spec:
  replicas: 1
  selector:
    matchLabels:
      app: postgresql
  template:
    metadata:
      labels:
        app: postgresql
    spec:
      containers:
      - name: postgresql
        image: {{ ocp4_workload_gitlab_postgresql_image }}:{{ ocp4_workload_gitlab_postgresql_image_tag }}
        env:
        - name: POSTGRESQL_USER
          valueFrom:
            secretKeyRef:
              name: gitlab-secrets
              key: POSTGRES_USER
        - name: POSTGRESQL_PASSWORD
          valueFrom:
            secretKeyRef:
              name: gitlab-secrets
              key: POSTGRES_PASSWORD
        - name: POSTGRESQL_DATABASE
          valueFrom:
            secretKeyRef:
              name: gitlab-secrets
              key: POSTGRES_DB
        ports:
        - containerPort: 5432
          name: postgresql
        volumeMounts:
        - name: postgresql-data
          mountPath: /var/lib/pgsql/data
        livenessProbe:
          exec:
            command:
            - /usr/libexec/check-container
            - --live
          initialDelaySeconds: 120
          periodSeconds: 10
        readinessProbe:
          exec:
            command:
            - /usr/libexec/check-container
          initialDelaySeconds: 5
          periodSeconds: 10
      volumes:
      - name: postgresql-data
        persistentVolumeClaim:
          claimName: postgresql-data
---
apiVersion: v1
kind: Service
metadata:
  name: postgresql
  namespace: {{ ocp4_workload_gitlab_namespace }}
  labels:
    app: postgresql
spec:
  ports:
  - port: 5432
    targetPort: 5432
    name: postgresql
  selector:
    app: postgresql
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: redis
  namespace: {{ ocp4_workload_gitlab_namespace }}
  labels:
    app: redis
spec:
  replicas: 1
  selector:
    matchLabels:
      app: redis
  template:
    metadata:
      labels:
        app: redis
    spec:
      containers:
      - name: redis
        image: {{ ocp4_workload_gitlab_redis_image }}:{{ ocp4_workload_gitlab_redis_image_tag }}
        env:
        - name: REDIS_PASSWORD
          valueFrom:
            secretKeyRef:
              name: gitlab-secrets
              key: REDIS_PASSWORD
        ports:
        - containerPort: 6379
          name: redis
        livenessProbe:
          tcpSocket:
            port: 6379
          initialDelaySeconds: 30
          periodSeconds: 10
        readinessProbe:
          exec:
            command:
            - redis-cli
            - ping
          initialDelaySeconds: 5
          periodSeconds: 10
---
apiVersion: v1
kind: Service
metadata:
  name: redis
  namespace: {{ ocp4_workload_gitlab_namespace }}
  labels:
    app: redis
spec:
  ports:
  - port: 6379
    targetPort: 6379
    name: redis
  selector:
    app: redis
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gitlab
  namespace: {{ ocp4_workload_gitlab_namespace }}
  labels:
    app: gitlab
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: gitlab
  template:
    metadata:
      labels:
        app: gitlab
    spec:
      serviceAccountName: gitlab-ce
      containers:
      - name: gitlab
        image: {{ ocp4_workload_gitlab_image }}:{{ ocp4_workload_gitlab_image_tag }}
        env:
        - name: GITLAB_OMNIBUS_CONFIG
          value: |
            external_url 'https://{{ _ocp4_workload_gitlab_route }}'
            gitlab_rails['initial_root_password'] = ENV['GITLAB_ROOT_PASSWORD']
            postgresql['enable'] = false
            gitlab_rails['db_adapter'] = 'postgresql'
            gitlab_rails['db_encoding'] = 'unicode'
            gitlab_rails['db_host'] = 'postgresql'
            gitlab_rails['db_port'] = 5432
            gitlab_rails['db_database'] = ENV['POSTGRES_DB']
            gitlab_rails['db_username'] = ENV['POSTGRES_USER']
            gitlab_rails['db_password'] = ENV['POSTGRES_PASSWORD']
            redis['enable'] = false
            gitlab_rails['redis_host'] = 'redis'
            gitlab_rails['redis_port'] = 6379
            gitlab_rails['redis_password'] = ENV['REDIS_PASSWORD']
            nginx['listen_port'] = 8080
            nginx['listen_https'] = false
            gitlab_rails['gitlab_shell_ssh_port'] = 2222
            puma['port'] = 0
            puma['worker_processes'] = 2
            puma['min_threads'] = 4
            puma['max_threads'] = 4
            puma['worker_timeout'] = 60
            puma['per_worker_max_memory_mb'] = 1024
{% if ocp4_workload_gitlab_auth_mode == 'keycloak' %}
            gitlab_rails['omniauth_enabled'] = true
            gitlab_rails['omniauth_allow_single_sign_on'] = ['openid_connect']
            gitlab_rails['omniauth_block_auto_created_users'] = false
            gitlab_rails['omniauth_providers'] = [
              {
                'name' => 'openid_connect',
                'label' => 'Keycloak',
                'args' => {
                  'name' => 'openid_connect',
                  'scope' => ['openid','profile','email'],
                  'response_type' => 'code',
                  'issuer' => 'https://{{ _ocp4_workload_gitlab_keycloak_url }}/realms/{{ ocp4_workload_gitlab_keycloak_realm }}',
                  'discovery' => true,
                  'client_auth_method' => 'query',
                  'uid_field' => 'preferred_username',
                  'client_options' => {
                    'identifier' => '{{ ocp4_workload_gitlab_keycloak_client_id }}',
                    'secret' => ENV['KEYCLOAK_CLIENT_SECRET'],
                    'redirect_uri' => 'https://{{ _ocp4_workload_gitlab_route }}/users/auth/openid_connect/callback'
                  }
                }
              }
            ]
{% endif %}
        - name: GITLAB_ROOT_PASSWORD
          valueFrom:
            secretKeyRef:
              name: gitlab-secrets
              key: GITLAB_ROOT_PASSWORD
        - name: POSTGRES_USER
          valueFrom:
            secretKeyRef:
              name: gitlab-secrets
              key: POSTGRES_USER
        - name: POSTGRES_PASSWORD
          valueFrom:
            secretKeyRef:
              name: gitlab-secrets
              key: POSTGRES_PASSWORD
        - name: POSTGRES_DB
          valueFrom:
            secretKeyRef:
              name: gitlab-secrets
              key: POSTGRES_DB
        - name: REDIS_PASSWORD
          valueFrom:
            secretKeyRef:
              name: gitlab-secrets
              key: REDIS_PASSWORD
{% if ocp4_workload_gitlab_auth_mode == 'keycloak' %}
        - name: KEYCLOAK_CLIENT_SECRET
          value: "{{ _ocp4_workload_gitlab_keycloak_client_secret }}"
{% endif %}
        ports:
        - containerPort: 8080
          name: http
        - containerPort: 2222
          name: ssh
        volumeMounts:
        - name: gitlab-data
          mountPath: /etc/gitlab
          subPath: config
        - name: gitlab-data
          mountPath: /var/log/gitlab
          subPath: logs
        - name: gitlab-data
          mountPath: /var/opt/gitlab
          subPath: data
        resources:
          requests:
            memory: {{ ocp4_workload_gitlab_memory_request }}
            cpu: {{ ocp4_workload_gitlab_cpu_request }}
          limits:
            memory: {{ ocp4_workload_gitlab_memory_limit }}
            cpu: {{ ocp4_workload_gitlab_cpu_limit }}
        livenessProbe:
          exec:
            command:
            - /bin/sh
            - -c
            - curl -f http://localhost:8080/-/liveness
          initialDelaySeconds: 300
          periodSeconds: 30
          timeoutSeconds: 10
        readinessProbe:
          exec:
            command:
            - /bin/sh
            - -c
            - curl -f http://localhost:8080/-/readiness
          initialDelaySeconds: 180
          periodSeconds: 10
          timeoutSeconds: 5
      volumes:
      - name: gitlab-data
        persistentVolumeClaim:
          claimName: gitlab-data
---
apiVersion: v1
kind: Service
metadata:
  name: gitlab
  namespace: {{ ocp4_workload_gitlab_namespace }}
  labels:
    app: gitlab
spec:
  ports:
  - port: 8080
    targetPort: 8080
    name: http
  - port: 2222
    targetPort: 2222
    name: ssh
  selector:
    app: gitlab
---
apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: gitlab
  namespace: {{ ocp4_workload_gitlab_namespace }}
  labels:
    app: gitlab
spec:
{% if _ocp4_workload_gitlab_hostname | default("") | length > 0 %}
  host: {{ _ocp4_workload_gitlab_hostname }}
{% endif %}
  to:
    kind: Service
    name: gitlab
  port:
    targetPort: http
{% if ocp4_workload_gitlab_ssl_route | bool %}
  tls:
    termination: edge
    insecureEdgeTerminationPolicy: Redirect
{% endif %}
