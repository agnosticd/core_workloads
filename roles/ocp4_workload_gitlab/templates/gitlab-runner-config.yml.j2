---
kind: ConfigMap
apiVersion: v1
metadata:
  name: gitlab-runner-config
  namespace: {{ ocp4_workload_gitlab_namespace }}
data:
  register-template.toml: |
    [[runners]]
      environment = ["STORAGE_DRIVER=vfs", "BUILDAH_FORMAT=docker", "BUILDAH_ISOLATION=chroot", "KUBERNETES_SERVICE_ACCOUNT_OVERWRITE=gitlab-runner"]
      {% if ocp4_workload_gitlab_runner_executor == 'kubernetes' %}
      [runners.kubernetes]
        [runners.kubernetes.pod_security_context]
          run_as_non_root = false
          run_as_user = 0
        [runners.kubernetes.build_container_security_context]
          run_as_user = 0
          [runners.kubernetes.build_container_security_context.capabilities]
            add = ["SETFCAP", "MKNOD"]
      {% endif %}
